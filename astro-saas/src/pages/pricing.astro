---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Pricing | Astro Vedic SaaS">
  <main class="mx-auto max-w-5xl px-6 py-16 space-y-4">
    <h1 class="text-3xl font-semibold">Pricing</h1>
    <p id="status" class="text-sm text-[var(--text)]/80"></p>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <article class="rounded-xl border border-white/10 bg-[var(--surface)] p-5">
        <h2 class="text-xl font-medium">Free</h2>
        <p class="mt-2 text-[var(--text)]/70">1 chart/month, limited reading.</p>
      </article>
      <article class="rounded-xl border border-[var(--primary)]/50 bg-[var(--surface)] p-5">
        <h2 class="text-xl font-medium">Pro</h2>
        <p class="mt-2 text-[var(--text)]/70">Unlimited charts and chatbot.</p>
        <div class="mt-4 flex gap-2">
          <button class="checkout rounded-md bg-[var(--primary)] px-3 py-1 text-sm font-semibold text-black" data-plan="pro_monthly">Pro Monthly</button>
          <button class="checkout rounded-md border border-white/15 px-3 py-1 text-sm" data-plan="pro_yearly">Pro Yearly</button>
        </div>
      </article>
      <article class="rounded-xl border border-white/10 bg-[var(--surface)] p-5">
        <h2 class="text-xl font-medium">Lifetime</h2>
        <p class="mt-2 text-[var(--text)]/70">One-time purchase with full access.</p>
        <button class="checkout mt-4 rounded-md bg-[var(--secondary)] px-3 py-1 text-sm font-semibold" data-plan="lifetime">Buy Lifetime</button>
      </article>
    </div>
  </main>
</Layout>

<script is:inline>
  const token = window.localStorage.getItem("astro_access_token");
  const statusNode = document.getElementById("status");
  const buttons = Array.from(document.querySelectorAll(".checkout"));

  async function startCheckout(plan) {
    if (!token) {
      statusNode.textContent = "Login required before checkout.";
      return;
    }
    statusNode.textContent = "Creating checkout session...";
    const res = await fetch("/api/checkout", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${token}`,
      },
      body: JSON.stringify({ plan }),
    });
    const json = await res.json();
    if (!res.ok) {
      statusNode.textContent = json.error ?? "Unable to start checkout.";
      return;
    }
    if (json.url) {
      window.location.href = json.url;
    }
  }

  for (const button of buttons) {
    button.addEventListener("click", () => startCheckout(button.dataset.plan));
  }
</script>
