---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Dashboard | Astro Vedic SaaS">
  <main class="mx-auto max-w-6xl px-6 py-12 space-y-6">
    <section class="rounded-2xl border border-[var(--primary)]/40 bg-[var(--surface)] p-6">
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--primary)]">Astro Dashboard</p>
      <h1 class="mt-2 text-3xl font-semibold">Your Vedic Profile Center</h1>
      <p class="mt-2 text-[var(--text)]/80">
        View your traits, active dasha period, yogas, and personalized predictions in one place.
      </p>
      <div class="mt-4 flex gap-3">
        <a class="rounded-md bg-[var(--primary)] px-4 py-2 font-semibold text-black" href="/app">New Kundli</a>
        <button id="logout" class="rounded-md border border-white/15 px-4 py-2" type="button">Logout</button>
      </div>
    </section>

    <section class="grid gap-4 md:grid-cols-4">
      <article class="rounded-xl border border-white/10 bg-[var(--surface)] p-4">
        <p class="text-xs text-[var(--muted)]">Charts Generated</p>
        <p id="kpi-count" class="mt-2 text-2xl font-semibold">0</p>
      </article>
      <article class="rounded-xl border border-white/10 bg-[var(--surface)] p-4">
        <p class="text-xs text-[var(--muted)]">Latest Lagna</p>
        <p id="kpi-lagna" class="mt-2 text-2xl font-semibold">-</p>
      </article>
      <article class="rounded-xl border border-white/10 bg-[var(--surface)] p-4">
        <p class="text-xs text-[var(--muted)]">Latest Moon Sign</p>
        <p id="kpi-moon" class="mt-2 text-2xl font-semibold">-</p>
      </article>
      <article class="rounded-xl border border-white/10 bg-[var(--surface)] p-4">
        <p class="text-xs text-[var(--muted)]">Current Mahadasha</p>
        <p id="kpi-dasha" class="mt-2 text-2xl font-semibold">-</p>
      </article>
    </section>

    <p id="status" class="text-sm text-[var(--text)]/80"></p>
    <div id="charts" class="grid gap-3 md:grid-cols-2"></div>
    <div id="empty" class="hidden rounded-xl border border-white/10 bg-[var(--surface)] p-5 text-sm text-[var(--text)]/70">
      No charts yet. Create your first one.
    </div>
  </div>
  </main>
</Layout>

<script is:inline>
  const logoutButton = document.getElementById("logout");
  const statusNode = document.getElementById("status");
  const chartsNode = document.getElementById("charts");
  const emptyNode = document.getElementById("empty");
  const kpiCount = document.getElementById("kpi-count");
  const kpiLagna = document.getElementById("kpi-lagna");
  const kpiMoon = document.getElementById("kpi-moon");
  const kpiDasha = document.getElementById("kpi-dasha");

  const token = window.localStorage.getItem("astro_access_token");
  statusNode.textContent = token ? "Authenticated mode." : "Auth bypass mode active.";
  const headers = {};
  if (token) {
    headers.Authorization = `Bearer ${token}`;
  }
  fetch("/api/charts", { headers })
      .then(async (res) => {
        const json = await res.json();
        if (!res.ok) throw new Error(json.error ?? "Unable to load charts.");
        const charts = json.charts ?? [];
        kpiCount.textContent = String(charts.length);

        if (!charts.length) {
          emptyNode.classList.remove("hidden");
          return;
        }

        const latestRaw = charts[0]?.raw_calculation ?? {};
        kpiLagna.textContent = latestRaw.lagna ?? "-";
        kpiMoon.textContent = latestRaw.moon_sign ?? "-";
        kpiDasha.textContent = latestRaw?.current_dasha?.mahadasha ?? "-";

        chartsNode.innerHTML = charts
          .map(
            (chart) => `
              <article class="rounded-xl border border-white/10 bg-[var(--surface)] p-4">
                <p class="font-medium text-lg">${chart.full_name}</p>
                <p class="text-sm text-[var(--text)]/70">${chart.birth_date} ${chart.birth_time} • ${chart.birth_location}</p>
                <div class="mt-3 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full border border-[var(--primary)]/40 px-2 py-1">Lagna: ${chart?.raw_calculation?.lagna ?? "-"}</span>
                  <span class="rounded-full border border-[var(--secondary)]/40 px-2 py-1">Moon: ${chart?.raw_calculation?.moon_sign ?? "-"}</span>
                  <span class="rounded-full border border-white/20 px-2 py-1">Dasha: ${chart?.raw_calculation?.current_dasha?.mahadasha ?? "-"}</span>
                </div>
                <p class="mt-3 line-clamp-2 text-sm text-[var(--text)]/70">${chart?.ai_reading?.text ?? "Detailed reading available inside full report."}</p>
                <div class="mt-3 flex gap-2">
                  <a class="rounded-md bg-[var(--primary)] px-3 py-1 text-sm font-semibold text-black" href="/app/chart/${chart.id}">Full Report</a>
                  <a class="rounded-md border border-white/15 px-3 py-1 text-sm" href="/app/chat/${chart.id}">Ask AstroBot</a>
                </div>
              </article>
            `,
          )
          .join("");
      })
      .catch((error) => {
        statusNode.textContent = error instanceof Error ? error.message : "Unexpected error.";
      });

  logoutButton?.addEventListener("click", () => {
    window.localStorage.removeItem("astro_access_token");
    statusNode.textContent = "Logged out.";
    window.setTimeout(() => {
      window.location.href = "/auth/login";
    }, 400);
  });
</script>
