# Astro Intelligence System - Environment Variables
# Copy this file to backend/.env and fill in your values.

# NVIDIA NIM API
NVIDIA_EMBED_API_KEY=your-nvidia-embed-key
NVIDIA_CHAT_API_KEY=your-nvidia-chat-key
NVIDIA_WHISPER_API_KEY=your-nvidia-whisper-key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct

# Ollama (local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_PORT=50051

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://ais_user:ais_password@localhost:5432/ais_db
SYNC_DATABASE_URL=postgresql://ais_user:ais_password@localhost:5432/ais_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Swiss Ephemeris
# Leave blank to use bundled ephemeris, or set a path to downloaded SE files.
SWISSEPH_PATH=

# Ephemeris settings
DEFAULT_AYANAMSA=1
DEFAULT_HOUSE_SYSTEM=W

# App settings
APP_ENV=development
LOG_LEVEL=INFO
API_KEY=changeme-local-dev-key
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ENABLE_LLM_SYNTHESIS=true
